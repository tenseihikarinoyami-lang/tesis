rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isProjectOwner(projectId) {
      return isSignedIn() && 
        get(/databases/$(database)/documents/projects/$(projectId)).data.userId == request.auth.uid;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'subscription']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['student', 'admin'] &&
             data.subscription in ['free', 'pro'];
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasAny(['email', 'subscription', 'role']);
    }

    // Projects
    match /projects/{projectId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Sub-collections
      match /chunks/{chunkId} {
        allow read, write: if isProjectOwner(projectId);
      }
      
      match /citations/{citationId} {
        allow read, write: if isProjectOwner(projectId);
      }
    }
  }
}
