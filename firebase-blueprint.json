{
  "entities": {
    "AppUser": {
      "title": "App User",
      "description": "Metadata for application users including roles and expiration",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "researcher"] },
        "expiresAt": { "type": "number" },
        "createdAt": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "expired", "pending"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "users": {
      "schema": "AppUser",
      "description": "User permissions and expiration tracking"
    },
    "thesis_projects": {
      "schema": "ThesisProject",
      "description": "Main collection for thesis documents"
    }
  }
}
